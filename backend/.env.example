PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/togt
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
PEACH_ENTITY_ID=your_peach_entity_id
PEACH_ACCESS_TOKEN=your_peach_access_token
PEACH_BASE_URL=https://eu-test.oppwa.com

# CORS — comma-separated list of allowed origins. Leave empty in dev to allow any.
# Example: CORS_ORIGINS=https://togt.co.za,https://admin.togt.co.za
CORS_ORIGINS=

# Peach Payments webhook HMAC secret. REQUIRED in production — without it
# the /payments/webhook handler refuses to mark payments paid (auth-bypass
# protection). Dev/test allow unset; the route logs a warning and skips
# signature checking so local development doesn't need a real Peach setup.
PEACH_WEBHOOK_SECRET=

# Resend (password reset emails)
RESEND_API_KEY=
RESEND_FROM=Togt <onboarding@resend.dev>

# VerifyNow — SA DHA-linked ID verification (https://www.verifynow.co.za)
# Mode: sandbox (free, mock data) or production (R2.99/credit, real DHA)
VERIFYNOW_API_KEY=
VERIFYNOW_MODE=sandbox

# Cloudinary (profile photo + selfie uploads via multer-storage-cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 32 bytes (64 hex chars). Generate: node -e "console.log(require(\"crypto\").randomBytes(32).toString(\"hex\"))"
WEBHOOK_SECRET_ENCRYPTION_KEY=

# OpenAPI / problem-detail base. Used in error type URIs and the
# servers[] block of the OpenAPI spec. Optional in dev (defaults to
# https://api.togt.co.za and http://localhost:3002).
API_PUBLIC_BASE_URL=
API_PUBLIC_HOST=

# Set to '1' to force the SSRF private-IP guard ON in non-production
# (e.g. CI). The guard is automatically on under NODE_ENV=production.
WEBHOOK_SSRF_FORCE=

# Set to '1' to force the rate limiters to apply in test mode (used by
# rateLimit.test.js to assert the limiter actually rejects). Without
# this, all limiters are no-ops under NODE_ENV=test.
RATELIMIT_FORCE=

# DB pool tuning — defaults are sane for single-process dev (10/30s/5s/15s).
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=5000
# PG_STATEMENT_TIMEOUT_MS=15000
