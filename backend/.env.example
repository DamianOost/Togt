PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/togt
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
PEACH_ENTITY_ID=your_peach_entity_id
PEACH_ACCESS_TOKEN=your_peach_access_token
PEACH_BASE_URL=https://eu-test.oppwa.com

# CORS — comma-separated list of allowed origins. Leave empty in dev to allow any.
# Example: CORS_ORIGINS=https://togt.co.za,https://admin.togt.co.za
CORS_ORIGINS=

# Peach Payments webhook HMAC secret (confirm scheme with Peach CEO)
PEACH_WEBHOOK_SECRET=

# Resend (password reset emails)
RESEND_API_KEY=
RESEND_FROM=Togt <onboarding@resend.dev>
